# Bitmovin Player
VITE_BITMOVIN_KEY=your-bitmovin-player-key

# Stream URLs
VITE_STREAM_URL=https://your-stream.akamaized.net/path/manifest.m3u8

# Bitmovin Encoding
VITE_BITMOVIN_API_KEY=your-bitmovin-api-key
VITE_BITMOVIN_ORG_ID=your-org-id

# Unified Streaming
VITE_USP_ORIGIN_URL=https://your-unified-origin.example.com
VITE_USP_CHANNEL_MANIFEST=channel-schedule.smil

# MediaMelon Analytics
VITE_MM_CUSTOMER_ID=your-mediamelon-customer-id
VITE_MM_DASHBOARD_URL=https://your-mediamelon-dashboard-url

# TrafficPeak Analytics
VITE_TRAFFICPEAK_URL=https://dashboards.trafficpeak.live/public-dashboards/your-dashboard-id

# VPU Demo (Wetty web terminals)
VITE_VPU_CPU_VM_URL=https://cpuvm.example.com/wetty
VITE_VPU_VPU_VM_URL=https://vpuvm.example.com/wetty

# Anti-Piracy Demo Portal
VITE_ANTIPIRACY_DEMO_URL=https://your-antipiracy-demo-portal-url
